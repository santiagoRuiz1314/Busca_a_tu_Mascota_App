rules_version = '2';

// Reglas de seguridad de Cloud Firestore para BuscaMascota.
//
// La base se creó en modo producción (deniega todo por defecto), por eso el
// primer reporte fallaba con PERMISSION_DENIED. Estas reglas habilitan el
// uso real con autenticación. Ya reflejan la intención de la Fase 7
// (lectura autenticada; escritura solo por el dueño / propio uid).
//
// CÓMO PUBLICARLAS: Firebase Console → proyecto buscamascota-a15a6 →
// Build → Firestore Database → pestaña "Rules" → pegar este contenido →
// "Publish". (No hay Firebase CLI configurado en el repo.)

service cloud.firestore {
  match /databases/{database}/documents {

    // Reportes: cualquier usuario autenticado puede leerlos; solo el dueño
    // puede crear (con su propio uid) y modificar/borrar los suyos.
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerId == request.auth.uid;
    }

    // Perfil de usuario: lectura autenticada; cada quien escribe solo el suyo.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
